pico-8 cartridge // http://www.pico-8.com
version 30
__lua__
function _init()
sigx={}
sigy={}
cls()
for x=0,15 do
for y=0,12 do
spr(mget(x,y),8*x,8*y)
end
end
--engine coord
tx={}
ty={}
--colors under train
tc={}
--time to wait
tw={}
--train kind/kolor
tk={}
--train will turn at switch
tt={}
--train inside signal
ts={}
--num trains
nt=1
for x=0,127 do
for y=0,127 do
if pget(x,y)==15 then
xs={x,x-1,x-2,x-3,x-4}
ys={y,y,y,y,y}
cs={7,7,7,7,7}
tx[nt]=xs
ty[nt]=ys
tc[nt]=cs
tw[nt]=0
tk[nt]=pget(x-1,y)
tt[nt]=false
ts[nt]=false
nt+=1
end
end
end
end

function find(v,a)
for x in all(v) do
if(x==a)return true
end
return false
end

function signal(x,y)
sigcol(x,y,11,8)
end

function sigcol(x,y,oldc,newc)
ky=128*x+y+128*128*oldc
if sigx[ky]==nil then
 sfx(2)
 sigx[ky]={}
 sigy[ky]={}
 nex={}
 for dx=-1,1 do
 for dy=-1,1 do
 add(nex,128*(dx+x)+dy+y)
 end
 end
 vis={}
 while #nex>0 do
  n=nex[1]
  del(nex,n)
  if not find(vis,n) then
   add(vis,n)
   nx=flr(n/128)
   ny=n-128*nx
   ch=pget(nx,ny)
   ct=pget(nx,ny-1)
   if ch==4 or ch==7 or ch==10 or ch==6 then
    if ch==4 and ct==oldc then
     add(sigx[ky],nx)
     add(sigy[ky],ny-1)
     pset(nx,ny-1,newc)
    else
     for dx=-1,1 do
      for dy=-1,1 do
       m=128*(nx+dx)+ny+dy
       if(not find(vis,m))add(nex,m)
      end
     end
    end
   end
  end
 end
end
for i=1,#sigx[ky] do
 pset(sigx[ky][i],sigy[ky][i],newc)
end
end

function unsignal(x,y)
sigcol(x,y,8,11)
end

function step(i,nx,ny)
nc=pget(nx,ny)
if nc==7 or nc==10 or nc==4 or nc==6 then
if tw[i]>0 then
tw[i]-=1
return true
end
ca=pget(nx,ny-1)
if nc==4 and ca==8 then
if(not ts[i]) return true
end
if nc==6 and (ca==tk[i] or ca==7) then
tt[i]=true
end
pset(tx[i][5],ty[i][5],tc[i][5])
x5=tx[i][5]
y5=ty[i][5]-1
c5=pget(x5,y5)
if tc[i][5]==4 and c5!=3 then
if c5==9 then
pset(x5,y5,8)
else
unsignal(x5,y5)
ts[i]=false
end
end
if tc[i][2]==10 then
tt[i]=false
end
pset(xa,ya,tk[i])
for j=5,1,-1 do
tx[i][j+1]=tx[i][j]
ty[i][j+1]=ty[i][j]
tc[i][j+1]=tc[i][j]
end
tx[i][1]=nx
ty[i][1]=ny
tc[i][1]=nc
if nc==4 and ca==3 then
tw[i]=30
else
tw[i]=1
if(tk[i]==12 or tk[i]==2 or tk[i]==8)tw[i]=0
end
if nc==4 and ca==11 then
signal(nx,ny,true)
pset(nx,ny-1,9)
ts[i]=true
end
pset(nx,ny,15)
return true
end
return false
end

function f(x)
if(x>0)return 1
if(x<0)return -1
return 0
end

function free(x,y)
c=pget(x,y)
return c==3 or c==7 or c==4 or c==10 or c==6
end

function _update()
for i=1,nt-1 do
xa=tx[i][1]
ya=ty[i][1]
dx=tx[i][1]-tx[i][2]
dy=ty[i][1]-ty[i][2]
lx=f(dx-dy)
ly=f(dy+dx)
rx=f(dx+dy)
ry=f(dy-dx)
if free(xa+dx,ya+dy) then
if tt[i] then
if not step(i,xa+rx,ya+ry) then
if not step(i,xa+lx,ya+ly) then
if not step(i,xa+dx,ya+dy) then
end
end
end
else
if not step(i,xa+dx,ya+dy) then
if not step(i,xa+rx,ya+ry) then
if not step(i,xa+lx,ya+ly) then
end
end
end
end
end
end
end

function _draw()

end

